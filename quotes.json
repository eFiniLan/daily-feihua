{
  "version": "2026-06-16",
  "count": 130,
  "generated_by": "Mavis (manual curation, sourced from 微博/知乎/網易雲音樂/公眾號/段子)",
  "stars_legend": "1=微廢(just stating the obvious) 2=入門 3=中度繞圈 4=高品質繞圈 5=神級廢話",
  "quotes": [
    { "id": 1, "text": "聽君一席話，如聽一席話。", "level": 5, "category": "繞口令", "source": "網絡流行(2021)" },
    { "id": 2, "text": "吃麵不吃蒜，等於沒吃蒜。", "level": 4, "category": "生活觀察", "source": "網絡流行" },
    { "id": 3, "text": "你說的這話，拋開內容來說，我十分贊同。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 4, "text": "萬里無雲的天空，沒有一片雲。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 5, "text": "但凡你有點本事，也不至於一點本事也沒有哇。", "level": 5, "category": "毒舌繞圈", "source": "網絡流行" },
    { "id": 6, "text": "我曾在極度憤怒的情況下極度憤怒！", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 7, "text": "希望下次見到你是在下次。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 8, "text": "據我所知，我一無所知。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 9, "text": "剝開香蕉後，你會發現一個剝了皮的香蕉。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 10, "text": "夕陽無限好，好就好。", "level": 4, "category": "廢話古詩", "source": "改寫自李商隱" },
    { "id": 11, "text": "這個西紅柿，竟然有股番茄味兒。", "level": 4, "category": "生活觀察", "source": "網絡流行" },
    { "id": 12, "text": "子曰：三人行，必有三人。", "level": 5, "category": "廢話古文", "source": "改寫自《論語》" },
    { "id": 13, "text": "七日不見，如隔一週。", "level": 5, "category": "廢話古文", "source": "改寫自《西廂記》" },
    { "id": 14, "text": "一日不見，如隔一日。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 15, "text": "螃蟹死之前還是活的。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 16, "text": "上次這麼無語還是上次。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 17, "text": "關於明天的事，你後天就知道了。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 18, "text": "如果不出意外的話應該是出意外了。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 19, "text": "我前腳剛走，後腳就跟上了。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 20, "text": "年紀輕輕就這麼年輕了。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 21, "text": "能力越大，能力就越大。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 22, "text": "俗話說得好：俗話說得好。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 23, "text": "統計顯示：未婚生育的人中竟然全部是女性。", "level": 4, "category": "廢話研究", "source": "網絡流行" },
    { "id": 24, "text": "把土豆切成厚厚的薄片。", "level": 4, "category": "矛盾描述", "source": "網絡流行" },
    { "id": 25, "text": "五彩斑斕的黑。", "level": 4, "category": "矛盾描述", "source": "甲方需求梗" },
    { "id": 26, "text": "情況就是這麼個情況，具體什麼情況，還得看情況。", "level": 5, "category": "官話繞圈", "source": "網絡流行" },
    { "id": 27, "text": "我睡覺的時候，完全不醒。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 28, "text": "我媽生我的那天正好是我的生日。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 29, "text": "如果你願意花點時間了解我，你就會發現花了點時間。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 30, "text": "相信我！你瘦下來一定很瘦！", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 31, "text": "雪崩的時候，沒有一片雪花是不崩的。", "level": 4, "category": "廢話古文", "source": "改寫自諺語" },
    { "id": 32, "text": "三句話，讓男人聽了我三句話。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 33, "text": "這件事告訴我們一個道理，就是告訴我們一個道理。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 34, "text": "床前明月光，疑是明月光。", "level": 4, "category": "廢話古詩", "source": "改寫自李白" },
    { "id": 35, "text": "十步殺一人，百步殺十人。", "level": 4, "category": "廢話古詩", "source": "改寫自李白" },
    { "id": 36, "text": "十年生死兩茫茫，五年生死一茫茫。", "level": 4, "category": "廢話古詩", "source": "改寫自蘇軾" },
    { "id": 37, "text": "千里江陵一日還，五百里江陵半日還。", "level": 4, "category": "廢話古詩", "source": "改寫自李白" },
    { "id": 38, "text": "春風又綠江南岸，江南岸被春風綠。", "level": 4, "category": "廢話古詩", "source": "改寫自王安石" },
    { "id": 39, "text": "粉身碎骨渾不怕，要留碎骨在人間。", "level": 4, "category": "廢話古詩", "source": "改寫自于謙" },
    { "id": 40, "text": "談笑有鴻儒，往來有鴻儒。", "level": 4, "category": "廢話古詩", "source": "改寫自劉禹錫" },
    { "id": 41, "text": "老夫聊發少年狂，左發狂，右發狂。", "level": 4, "category": "廢話古詩", "source": "改寫自蘇軾" },
    { "id": 42, "text": "春風十里揚州路，捲起珠簾總不如。", "level": 3, "category": "廢話古詩", "source": "改寫自杜牧" },
    { "id": 43, "text": "日出江花紅勝火，春來江水綠如藍。能不憶江南？", "level": 3, "category": "廢話古詩", "source": "原句白居易，加問號" },
    { "id": 44, "text": "明日複明日，明日何其多。", "level": 3, "category": "廢話古詩", "source": "原句《明日歌》" },
    { "id": 45, "text": "半斤八兩，一斤十六兩。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 46, "text": "但凡這句話有一點意義，也不至於一點意義都沒有。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 47, "text": "這個馬鈴薯長得跟土豆一樣。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 48, "text": "在掉鏈子這種事情上從未掉過鏈子。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 49, "text": "為什麼要討厭我們這些懶人，我們明明什麼都沒做。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 50, "text": "雖然我今天什麼也沒干，但還是辛苦我了。", "level": 4, "category": "自我安慰", "source": "網絡流行" },
    { "id": 51, "text": "我知道你的出發點是好的，但是你先別出發。", "level": 4, "category": "毒舌繞圈", "source": "網絡流行" },
    { "id": 52, "text": "我知道你很急，但是你先別急。", "level": 4, "category": "毒舌繞圈", "source": "網絡流行" },
    { "id": 53, "text": "睡覺的時候一定要閉上眼，不然會睡不著。", "level": 4, "category": "生活觀察", "source": "網絡流行" },
    { "id": 54, "text": "開門七件事：柴米油鹽醬醋茶，所以要開門。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 55, "text": "多喝熱水吧，因為喝熱水的時候水是熱的。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 56, "text": "兩情若是久長時，又豈能短到哪兒去。", "level": 4, "category": "廢話古詩", "source": "改寫自秦觀" },
    { "id": 57, "text": "人每呼吸一分鐘，就會少一分鐘的壽命。", "level": 4, "category": "廢話研究", "source": "網絡流行" },
    { "id": 58, "text": "我之前還沒發現，當我發現的時候我已經發現了。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 59, "text": "你不醜的話還挺好看的。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 60, "text": "安排的很好，下次別安排了。", "level": 4, "category": "毒舌繞圈", "source": "網絡流行" },
    { "id": 61, "text": "我一定能活到死。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 62, "text": "親媽該有的親媽樣子。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 63, "text": "做你自己，因為別人已經有人做了。", "level": 3, "category": "哲學廢話", "source": "網絡流行" },
    { "id": 64, "text": "閉上眼睛後眼前一片漆黑什麼也看不見。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 65, "text": "如果你從10層樓上跳下來還沒摔死，就說明你還活著。", "level": 4, "category": "廢話研究", "source": "網絡流行" },
    { "id": 66, "text": "鴕鳥不會飛，因為牠是鴕鳥。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 67, "text": "我國有14億人口，其中有我一個。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 68, "text": "看完記得點讚，不然我不會知道。", "level": 3, "category": "社交廢話", "source": "網絡流行" },
    { "id": 69, "text": "看完沒點讚的人也看完了。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 70, "text": "你說的這些話我左耳進右耳出，所以左耳進右耳出。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 71, "text": "每天叫醒我的不是夢想，是鬧鐘。", "level": 3, "category": "哲學廢話", "source": "網絡流行" },
    { "id": 72, "text": "我胖了。胖了。", "level": 3, "category": "描述廢話", "source": "網絡流行" },
    { "id": 73, "text": "我承認我說的不對，但是我不改。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 74, "text": "16歲少女10年前居然才6歲。", "level": 4, "category": "廢話研究", "source": "網絡流行" },
    { "id": 75, "text": "我不想卷了，但我也躺不平。", "level": 3, "category": "時代廢話", "source": "網絡流行(2023)" },
    { "id": 76, "text": "好的，沒問題，馬上（指三小時後）。", "level": 4, "category": "社交廢話", "source": "網絡流行" },
    { "id": 77, "text": "你說得對，但你先別說。", "level": 4, "category": "毒舌繞圈", "source": "網絡流行" },
    { "id": 78, "text": "我這個人很簡單，有事直接說。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 79, "text": "我已經想通了，但還沒完全想通。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 80, "text": "我的夢想是實現夢想。", "level": 4, "category": "哲學廢話", "source": "網絡流行" },
    { "id": 81, "text": "你很好，你很好，你真的很好。", "level": 3, "category": "社交廢話", "source": "網絡流行" },
    { "id": 82, "text": "你還在啊，你還在。", "level": 2, "category": "冷場王", "source": "網絡流行" },
    { "id": 83, "text": "我來了，我來了，我來了。", "level": 2, "category": "冷場王", "source": "網絡流行" },
    { "id": 84, "text": "嗯嗯，收到。", "level": 1, "category": "冷場王", "source": "社交真實" },
    { "id": 85, "text": "好的，收到，那我就先這樣了。", "level": 2, "category": "冷場王", "source": "社交真實" },
    { "id": 86, "text": "沒事就沒事吧。", "level": 1, "category": "冷場王", "source": "社交真實" },
    { "id": 87, "text": "我先去忙了。", "level": 1, "category": "冷場王", "source": "社交真實" },
    { "id": 88, "text": "嗯。", "level": 1, "category": "冷場王", "source": "社交真實" },
    { "id": 89, "text": "好的好的。", "level": 1, "category": "冷場王", "source": "社交真實" },
    { "id": 90, "text": "據說每個成功男人背後都有一個女人。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 91, "text": "我話說完，誰贊成，誰反對，誰棄權。", "level": 4, "category": "官話繞圈", "source": "網絡流行" },
    { "id": 92, "text": "我之前還沒發現，當我發現時我已經發現了。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 93, "text": "右眼看到的東西，左眼看不到。", "level": 4, "category": "描述廢話", "source": "網絡流行" },
    { "id": 94, "text": "陌生人，在嗎？你不在。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 95, "text": "我們終於又見面了，七日不見，如隔一週。", "level": 5, "category": "繞口令", "source": "網絡流行" },
    { "id": 96, "text": "張三給李四打電話，電話響了，張三掛了。", "level": 3, "category": "故事廢話", "source": "網絡流行" },
    { "id": 97, "text": "太陽東邊升起，西邊落下，方向感很好。", "level": 3, "category": "描述廢話", "source": "網絡流行" },
    { "id": 98, "text": "人會死，會。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 99, "text": "不要跟人吵架，萬一打贏了呢？", "level": 3, "category": "矛盾描述", "source": "網絡流行" },
    { "id": 100, "text": "年齡是個秘密，年齡。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 101, "text": "我胖了，這是一個事實，胖了。", "level": 3, "category": "描述廢話", "source": "網絡流行" },
    { "id": 102, "text": "過馬路的時候要看紅綠燈，綠燈行紅燈停。", "level": 3, "category": "生活觀察", "source": "網絡流行" },
    { "id": 103, "text": "有朋自遠方來，來了。", "level": 3, "category": "廢話古文", "source": "改寫自《論語》" },
    { "id": 104, "text": "學而時習之，習。", "level": 3, "category": "廢話古文", "source": "改寫自《論語》" },
    { "id": 105, "text": "老吾老以及人之老，幼吾幼以及人之幼。", "level": 3, "category": "廢話古文", "source": "原句《孟子》" },
    { "id": 106, "text": "事實證明，說的都是事實。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 107, "text": "我這個人最大的缺點就是缺點太多。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 108, "text": "我話不多，都在這幾句話裡。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 109, "text": "你要的我都有——我有的，給你。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 110, "text": "天黑了，所以天黑了。", "level": 3, "category": "描述廢話", "source": "網絡流行" },
    { "id": 111, "text": "加油，為了自己，加油。", "level": 3, "category": "自我安慰", "source": "網絡流行" },
    { "id": 112, "text": "今天又是充滿希望的一天，今天。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 113, "text": "我正在努力，努。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 114, "text": "看到這句話的時候，你在看這句話。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 115, "text": "你懂的，我也懂。", "level": 2, "category": "冷場王", "source": "網絡流行" },
    { "id": 116, "text": "我開門見山地說，這句話很開門。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 117, "text": "我考慮過了，我會考慮的。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 118, "text": "我不騙你，騙你是小狗。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 119, "text": "工作嘛，幹就完了，幹。", "level": 3, "category": "時代廢話", "source": "網絡流行" },
    { "id": 120, "text": "別人笑我太瘋癲，我笑他人看不穿。看得穿。", "level": 4, "category": "廢話古詩", "source": "改寫自唐寅" },
    { "id": 121, "text": "希望這次可以，這次。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 122, "text": "好的，我知道了，我知道了。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 123, "text": "我不笨，只是不夠聰明。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 124, "text": "有些話我不知道怎麼說，因為說不清楚。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 125, "text": "我說的每句話都是我想說的。", "level": 4, "category": "繞口令", "source": "網絡流行" },
    { "id": 126, "text": "今天的飯很好吃，今天。", "level": 3, "category": "描述廢話", "source": "網絡流行" },
    { "id": 127, "text": "話說到這份上，這份上。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 128, "text": "聽到沒，沒聽到？", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 129, "text": "不是說你，我是說我。", "level": 3, "category": "繞口令", "source": "網絡流行" },
    { "id": 130, "text": "看完就忘記了，忘記了。", "level": 3, "category": "繞口令", "source": "網絡流行" }
